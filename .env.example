# ── Google Gemini (Frontier) ───────────────────────────────────────────────────
# Free tier: 1500 requests/day — get key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── HuggingFace (OSS) ──────────────────────────────────────────────────────────
# Get a free token at https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# ── Model selection (optional — defaults shown) ────────────────────────────────
OSS_MODEL_ID=meta-llama/Llama-3.2-1B-Instruct
FRONTIER_MODEL_ID=gemini-2.0-flash

# ── App settings (optional) ────────────────────────────────────────────────────
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=false
